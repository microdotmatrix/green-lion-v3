---
import Layout from "@/layouts/default.astro";
import { db } from "@/lib/db";
import { blogPosts, blogCategories, user } from "@/lib/db/schema";
import { eq } from "drizzle-orm";
import { formatReadingTime } from "@/lib/reading-time";

const { slug } = Astro.params;

const [post] = await db
  .select({
    id: blogPosts.id,
    title: blogPosts.title,
    slug: blogPosts.slug,
    body: blogPosts.body,
    excerpt: blogPosts.excerpt,
    coverImageUrl: blogPosts.coverImageUrl,
    publishedAt: blogPosts.publishedAt,
    status: blogPosts.status,
    readTimeMinutes: blogPosts.readTimeMinutes,
    categoryName: blogCategories.name,
    categorySlug: blogCategories.slug,
    authorName: user.name,
  })
  .from(blogPosts)
  .leftJoin(blogCategories, eq(blogPosts.categoryId, blogCategories.id))
  .leftJoin(user, eq(blogPosts.authorId, user.id))
  .where(eq(blogPosts.slug, slug!))
  .limit(1);

if (!post || post.status !== "published") {
  return new Response(null, { status: 404 });
}

const readTime = formatReadingTime(post.readTimeMinutes);

function formatDate(date: Date | string | null): string {
  if (!date) return "";
  return new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(new Date(date));
}
---

<Layout
  title={post.title}
  description={post.excerpt}
  ogImage={post.coverImageUrl ?? undefined}
>
  <div class="post-hero">
    {
      post.coverImageUrl ? (
        <img src={post.coverImageUrl} alt={post.title} class="hero-image" />
      ) : (
        <div class="post-hero--placeholder" aria-hidden="true" />
      )
    }
  </div>

  <div class="content post-container">
    <h1 class="post-title">{post.title}</h1>

    <p class="post-byline">
      {post.authorName ? `By ${post.authorName} · ` : ""}
      {formatDate(post.publishedAt)} · {readTime}
    </p>

    {
      post.categoryName && post.categorySlug && (
        <a href={`/blog/category/${post.categorySlug}`} class="category-badge">
          {post.categoryName}
        </a>
      )
    }

    <div class="blog-prose" set:html={post.body} />

    <div class="post-footer">
      <a href="/blog" class="back-link">← Back to Blog</a>
    </div>
  </div>
</Layout>

<style>
  .post-hero {
    width: 100%;
    max-height: 75vh;
    overflow: hidden;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 16 / 9;
    display: block;
  }

  .post-hero--placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    max-height: 60vh;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--primary) 20%, var(--card)),
      color-mix(in srgb, var(--primary) 40%, var(--secondary))
    );
  }

  .post-container {
    max-width: 110ch;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .post-title {
    font-size: clamp(1.75rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .post-byline {
    color: var(--muted-foreground);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .category-badge {
    display: inline-block;
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    color: var(--primary);
    border-radius: var(--radius-md);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.625rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    width: fit-content;
    margin-bottom: 1.5rem;
    display: block;
  }

  .category-badge:hover {
    background: color-mix(in srgb, var(--primary) 20%, transparent);
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .back-link {
    color: var(--muted-foreground);
    text-decoration: none;
    font-size: 0.875rem;
  }

  .back-link:hover {
    color: var(--primary);
  }
</style>
