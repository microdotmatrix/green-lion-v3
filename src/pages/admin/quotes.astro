---
import "@/styles/global.css";

import { AdminQuotesPage } from "@/components/admin/pages/admin-quotes-page";
import { TailwindIndicator } from "@/components/elements/tailwind-indicator.tsx";
import Meta from "@/components/layout/meta.astro";
import { SITE } from "@/lib/config";

// Check if user is authenticated and has admin access
const user = Astro.locals.user;
const session = Astro.locals.session;

// Redirect if not authenticated
if (!user || !session) {
  return Astro.redirect("/signin?redirect=/admin/quotes");
}
---

<!doctype html>
<html lang="en" class="dark">
  <Meta title={`Quotes | Admin | ${SITE.title}`} description="Manage Quotes" />
  <body class="bg-zinc-950 text-zinc-50 antialiased">
    <AdminQuotesPage client:only="react" user={user} />
    {import.meta.env.DEV && <TailwindIndicator client:load />}
  </body>
</html>
