---
import Layout from "@/layouts/default.astro";
import { db } from "@/lib/db";
import {
  categories,
  customizationAttributes,
  pricingTiers,
  productAttributes,
  products,
} from "@/lib/db/schema";
import { eq, and, sql } from "drizzle-orm";

const categorySlug = Astro.params.category;
const productParam = Astro.params.product;

if (!categorySlug || !productParam) {
  return Astro.redirect("/products");
}

const [categoryData] = await db
  .select()
  .from(categories)
  .then((rows) =>
    rows.filter(
      (c) =>
        c.name
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, "-")
          .replace(/(^-|-$)/g, "") === categorySlug,
    ),
  );

if (!categoryData) {
  return Astro.redirect("/products");
}

const [productRow] = await db
  .select({
    id: products.id,
    sku: products.sku,
    name: products.name,
    description: products.description,
    images: products.images,
    minimumOrderQuantity: products.minimumOrderQuantity,
    orderQuantityIncrement: products.orderQuantityIncrement,
    categoryId: products.categoryId,
  })
  .from(products)
  .where(
    and(
      eq(products.categoryId, categoryData.id),
      sql`lower(${products.sku}) = ${productParam.toLowerCase()}`,
    ),
  )
  .limit(1);

if (!productRow) {
  return Astro.redirect(`/products/${categorySlug}`);
}

const productData = {
  ...productRow,
  categoryName: categoryData.name,
};

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=300, stale-while-revalidate=3600",
);

// Fetch pricing tiers for this product
const tiers = await db
  .select()
  .from(pricingTiers)
  .where(eq(pricingTiers.productId, productData.id))
  .orderBy(pricingTiers.minQuantity);

// Fetch product attributes with their definitions
const prodAttrs = await db
  .select({
    id: productAttributes.id,
    attributeId: productAttributes.attributeId,
    required: productAttributes.required,
    supportedOptions: productAttributes.supportedOptions,
    name: customizationAttributes.name,
    attributeType: customizationAttributes.attributeType,
  })
  .from(productAttributes)
  .innerJoin(
    customizationAttributes,
    eq(productAttributes.attributeId, customizationAttributes.id),
  )
  .where(eq(productAttributes.productId, productData.id));

const primaryImage = productData.images?.[0];
---

<Layout title={productData.name}>
  <section class="bg-gradient-to-b from-secondary to-background">
    <div class="content">
      <a
        href={`/products/${categorySlug}`}
        class="back-link inline-flex items-center gap-2 text-primary text-sm font-medium no-underline"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m12 19-7-7 7-7"></path>
          <path d="M19 12H5"></path>
        </svg>
        Back to {productData.categoryName || "Products"}
      </a>
    </div>
  </section>

  <section class="pb-16">
    <div class="content">
      <div class="grid gap-8 md:grid-cols-2 md:gap-12 lg:grid-cols-[1fr_1.2fr]">
        <!-- Product Image -->
        <div class="md:sticky md:top-8 h-fit">
          <div
            class="aspect-square bg-white rounded-lg border border-border flex items-center justify-center p-8 overflow-hidden"
          >
            {
              primaryImage ? (
                <img
                  src={primaryImage}
                  alt={productData.name}
                  class="max-w-full max-h-full object-contain"
                />
              ) : (
                <div class="text-muted-foreground opacity-30">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="80"
                    height="80"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect width="18" height="18" x="3" y="3" rx="2" ry="2" />
                    <circle cx="9" cy="9" r="2" />
                    <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
                  </svg>
                </div>
              )
            }
          </div>
        </div>

        <!-- Product Info -->
        <div class="flex flex-col gap-4">
          <span
            class="text-xs font-semibold text-muted-foreground uppercase tracking-widest"
            >SKU: {productData.sku}</span
          >
          <h1 class="text-2xl md:text-3xl font-bold m-0 leading-tight">
            {productData.name}
          </h1>
          <p class="text-base text-muted-foreground m-0 leading-relaxed">
            {productData.description}
          </p>

          <!-- Volume Pricing Card -->
          {
            tiers.length > 0 && (
              <div class="bg-card border border-border rounded-lg p-5 flex flex-col gap-3">
                <h3 class="text-sm font-semibold m-0 pb-2 border-b border-border">
                  Volume Pricing
                </h3>
                {tiers.map((tier) => (
                  <div class="flex justify-between items-baseline gap-4">
                    <span class="text-sm text-muted-foreground">
                      {tier.minQuantity.toLocaleString()}+ units
                    </span>
                    <span class="text-sm font-semibold text-primary">
                      ${parseFloat(tier.pricePerUnit).toFixed(2)}/unit
                    </span>
                  </div>
                ))}
                <p class="text-xs text-muted-foreground m-0 italic">
                  * Prices exclude shipping and import fees
                </p>
              </div>
            )
          }

          <!-- Customization Options Card -->
          {
            prodAttrs.length > 0 && (
              <div class="bg-card border border-border rounded-lg p-5 flex flex-col gap-3">
                <h3 class="text-sm font-semibold m-0 pb-2 border-b border-border">
                  Customization Options
                </h3>
                <div class="flex flex-wrap gap-x-6 gap-y-2">
                  {prodAttrs.map((attr) => (
                    <div class="flex items-center gap-2">
                      <span class="text-sm font-medium">{attr.name}:</span>
                      {attr.supportedOptions &&
                        attr.supportedOptions.length > 0 && (
                          <span class="text-sm text-muted-foreground flex items-center gap-1">
                            {attr.supportedOptions.map((opt, idx) => (
                              <>
                                {opt.toLowerCase() === "yes" ? (
                                  <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="text-primary"
                                  >
                                    <path d="M20 6 9 17l-5-5" />
                                  </svg>
                                ) : opt.toLowerCase() === "no" ? (
                                  <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="text-muted-foreground"
                                  >
                                    <path d="M18 6 6 18" />
                                    <path d="m6 6 12 12" />
                                  </svg>
                                ) : (
                                  <span>
                                    {opt}
                                    {idx <
                                    (attr.supportedOptions?.length ?? 0) - 1
                                      ? ","
                                      : ""}
                                  </span>
                                )}
                              </>
                            ))}
                          </span>
                        )}
                    </div>
                  ))}
                </div>
              </div>
            )
          }

          <!-- Order & Quantity Selector -->
          <div
            class="bg-secondary border border-border rounded-lg p-5 flex flex-col gap-4"
          >
            <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
              <div class="flex items-center gap-2">
                <span class="text-muted-foreground">MOQ:</span>
                <span class="font-semibold"
                  >{productData.minimumOrderQuantity.toLocaleString()}</span
                >
              </div>
              <div class="flex items-center gap-2">
                <span class="text-muted-foreground">Increment:</span>
                <span class="font-semibold"
                  >{productData.orderQuantityIncrement.toLocaleString()}</span
                >
              </div>
            </div>

            <div class="flex flex-wrap items-center gap-4">
              <div class="flex items-center gap-2">
                <button
                  type="button"
                  class="qty-btn w-10 h-10 flex items-center justify-center bg-background border border-border rounded-md text-xl text-foreground cursor-pointer"
                  id="qty-decrease"
                  aria-label="Decrease quantity"
                >
                  −
                </button>
                <input
                  type="number"
                  id="quantity-input"
                  value={productData.minimumOrderQuantity}
                  min={productData.minimumOrderQuantity}
                  step={productData.orderQuantityIncrement}
                  class="qty-input w-24 h-10 text-center bg-background border border-border rounded-md text-base font-semibold text-foreground"
                />
                <button
                  type="button"
                  class="qty-btn w-10 h-10 flex items-center justify-center bg-background border border-border rounded-md text-xl text-foreground cursor-pointer"
                  id="qty-increase"
                  aria-label="Increase quantity"
                >
                  +
                </button>
              </div>
              <div class="flex items-baseline gap-3">
                <span class="text-sm text-muted-foreground" id="unit-price">
                  {
                    tiers.length > 0
                      ? `$${parseFloat(tiers[0].pricePerUnit).toFixed(2)}/unit`
                      : "Contact for pricing"
                  }
                </span>
                <span class="text-lg font-bold text-primary" id="total-price">
                  {
                    tiers.length > 0
                      ? `$${(parseFloat(tiers[0].pricePerUnit) * productData.minimumOrderQuantity).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`
                      : "—"
                  }
                </span>
              </div>
            </div>
          </div>

          <!-- Add to Quote Button -->
          <button
            type="button"
            class="add-to-quote-btn flex items-center justify-center gap-2 py-4 px-8 bg-primary text-primary-foreground border-none rounded-md text-base font-semibold cursor-pointer mt-2"
            id="add-to-quote-btn"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="8" cy="21" r="1"></circle>
              <circle cx="19" cy="21" r="1"></circle>
              <path
                d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"
              ></path>
            </svg>
            Add to Quote Request
          </button>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ productData, tiers }}>
  const qtyInput = document.getElementById("quantity-input");
  const qtyDecrease = document.getElementById("qty-decrease");
  const qtyIncrease = document.getElementById("qty-increase");
  const qtyDisplay = document.getElementById("qty-display");
  const unitPriceEl = document.getElementById("unit-price");
  const totalPriceEl = document.getElementById("total-price");
  const addToQuoteBtn = document.getElementById("add-to-quote-btn");

  const moq = productData.minimumOrderQuantity;
  const increment = productData.orderQuantityIncrement;

  function getTierPrice(quantity) {
    if (!tiers || tiers.length === 0) return null;
    let applicableTier = tiers[0];
    for (const tier of tiers) {
      if (quantity >= tier.minQuantity) {
        applicableTier = tier;
      }
    }
    return parseFloat(applicableTier.pricePerUnit);
  }

  function updatePricing() {
    const qty = parseInt(qtyInput.value) || moq;
    const price = getTierPrice(qty);

    qtyDisplay.textContent = qty.toLocaleString();

    if (price !== null) {
      unitPriceEl.textContent = `$${price.toFixed(2)}/unit`;
      const total = price * qty;
      totalPriceEl.textContent = `$${total.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
    }
  }

  qtyDecrease?.addEventListener("click", () => {
    const currentVal = parseInt(qtyInput.value) || moq;
    const newVal = Math.max(moq, currentVal - increment);
    qtyInput.value = newVal;
    updatePricing();
  });

  qtyIncrease?.addEventListener("click", () => {
    const currentVal = parseInt(qtyInput.value) || moq;
    qtyInput.value = currentVal + increment;
    updatePricing();
  });

  qtyInput?.addEventListener("change", () => {
    let val = parseInt(qtyInput.value) || moq;
    if (val < moq) val = moq;
    // Round to nearest increment
    val = Math.round((val - moq) / increment) * increment + moq;
    qtyInput.value = val;
    updatePricing();
  });

  addToQuoteBtn?.addEventListener("click", () => {
    const qty = parseInt(qtyInput.value) || moq;
    const price = getTierPrice(qty);

    // Get existing cart from localStorage
    const existingCart = localStorage.getItem("quoteCart");
    const cart = existingCart ? JSON.parse(existingCart) : [];

    // Check if product already in cart
    const existingIndex = cart.findIndex(
      (item) => item.productId === productData.id,
    );

    if (existingIndex >= 0) {
      cart[existingIndex].quantity = qty;
      if (price) cart[existingIndex].price = price.toString();
    } else {
      cart.push({
        productId: productData.id,
        sku: productData.sku,
        name: productData.name,
        quantity: qty,
        price: price ? price.toString() : null,
      });
    }

    localStorage.setItem("quoteCart", JSON.stringify(cart));

    // Dispatch custom event for UI feedback
    window.dispatchEvent(
      new CustomEvent("quote-cart-updated", { detail: { productData } }),
    );

    // Show feedback
    const originalText = addToQuoteBtn.innerHTML;
    addToQuoteBtn.innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 6 9 17l-5-5"/>
      </svg>
      Added to Quote!
    `;
    addToQuoteBtn.disabled = true;

    setTimeout(() => {
      addToQuoteBtn.innerHTML = originalText;
      addToQuoteBtn.disabled = false;
    }, 2000);
  });
</script>

<style>
  /* Transition for back link gap on hover */
  .back-link {
    transition: gap 200ms ease;
  }
  .back-link:hover {
    gap: 0.75rem;
  }

  /* Quantity button hover transitions */
  .qty-btn {
    transition: all 150ms ease;
  }
  .qty-btn:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  /* Quantity input focus and spinner hiding */
  .qty-input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent);
  }
  .qty-input::-webkit-outer-spin-button,
  .qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .qty-input[type="number"] {
    -moz-appearance: textfield;
  }

  /* Add to quote button transitions and states */
  .add-to-quote-btn {
    transition:
      background 200ms ease,
      transform 100ms ease;
  }
  .add-to-quote-btn:hover {
    background: oklch(from var(--primary) calc(l * 0.9) c h);
  }
  .add-to-quote-btn:active {
    transform: scale(0.98);
  }
  .add-to-quote-btn:disabled {
    opacity: 0.8;
    cursor: default;
  }
</style>
