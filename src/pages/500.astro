---
import Layout from "@/layouts/default.astro";

// 500 pages cannot be prerendered (per Astro docs) — they always render
// on demand and receive the thrown `error` as a prop.
interface Props {
  error: unknown;
}

const { error } = Astro.props;

// Never expose stack traces or internal error details to visitors. We
// only surface a short, sanitized message in development to help debug.
const isDev = import.meta.env.DEV;
const safeMessage =
  isDev && error instanceof Error ? error.message : null;
---

<Layout
  title="Something Went Wrong"
  description="An unexpected error occurred while processing your request."
>
  <section class="error-hero">
    <div class="content text-center">
      <p class="error-eyebrow" aria-hidden="true">500</p>
      <h1>
        Something Went <span class="text-primary">Wrong</span>
      </h1>
      <p class="error-subtitle max-w-2xl mx-auto text-muted-foreground">
        We hit an unexpected error while loading this page. Our team has been
        notified. Please try again in a moment, or head back home.
      </p>

      <div class="error-actions">
        <a href="/" class="primary-action">Return Home</a>
        <a href="/contact" class="secondary-action">Contact Support</a>
      </div>

      {
        safeMessage && (
          <details class="error-details" aria-live="polite">
            <summary>Developer details</summary>
            <pre>{safeMessage}</pre>
          </details>
        )
      }
    </div>
  </section>

  <section class="error-tips-section">
    <div class="content">
      <h2 class="section-title accent-underline">What You Can Try</h2>
      <ul class="error-tips-grid">
        <li class="error-tip-card">
          <div class="error-tip-icon" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8" />
              <path d="M21 3v5h-5" />
            </svg>
          </div>
          <h3>Refresh the page</h3>
          <p>The issue may be temporary. Reloading often resolves it.</p>
        </li>
        <li class="error-tip-card">
          <div class="error-tip-icon" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m15 18-6-6 6-6" />
            </svg>
          </div>
          <h3>Go back</h3>
          <p>Return to the previous page and try a different path.</p>
        </li>
        <li class="error-tip-card">
          <div class="error-tip-icon" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"
              ></path>
            </svg>
          </div>
          <h3>Reach out</h3>
          <p>If the problem persists, our team is happy to help.</p>
        </li>
      </ul>
    </div>
  </section>
</Layout>

<script is:inline>
  // Wire up "Go back" tip card if it exists. Falls through gracefully
  // for users without JavaScript or referrers.
  document.addEventListener("DOMContentLoaded", () => {
    const backTip = document.querySelectorAll(".error-tip-card")[1];
    if (!backTip || !window.history || window.history.length <= 1) return;
    backTip.setAttribute("role", "button");
    backTip.setAttribute("tabindex", "0");
    backTip.style.cursor = "pointer";
    const goBack = (event) => {
      if (event.type === "keydown") {
        const key = event.key;
        if (key !== "Enter" && key !== " ") return;
        event.preventDefault();
      }
      window.history.back();
    };
    backTip.addEventListener("click", goBack);
    backTip.addEventListener("keydown", goBack);
  });
</script>

<style>
  .error-hero {
    background: linear-gradient(to bottom, var(--secondary), var(--background));
    padding-block: 4rem 3rem;
  }

  .error-eyebrow {
    font-family: var(--font-serif, serif);
    font-weight: 700;
    color: var(--destructive);
    letter-spacing: 0.2em;
    font-size: clamp(1rem, 0.9rem + 0.5vw, 1.25rem);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
  }

  .error-hero h1 {
    margin-bottom: 1rem;
  }

  .error-subtitle {
    margin-bottom: 2rem;
  }

  .error-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .primary-action,
  .secondary-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius);
    padding: 0.625rem 1.25rem;
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid transparent;
    transition:
      background-color 150ms ease,
      color 150ms ease,
      box-shadow 200ms ease;
  }

  .primary-action {
    background: var(--primary);
    color: var(--primary-foreground);
  }
  .primary-action:hover,
  .primary-action:focus-visible {
    box-shadow: 0 6px 18px hsl(var(--primary) / 0.25);
    background: oklch(from var(--primary) l c calc(h * 1.3));
  }

  .secondary-action {
    border-color: var(--primary);
    color: var(--primary);
    background: transparent;
  }
  .secondary-action:hover,
  .secondary-action:focus-visible {
    background: var(--primary);
    color: var(--primary-foreground);
  }

  .primary-action:focus-visible,
  .secondary-action:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
  }

  .error-details {
    margin-top: 2rem;
    text-align: left;
    max-width: 48rem;
    margin-inline: auto;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
  }
  .error-details > summary {
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--muted-foreground);
  }
  .error-details > pre {
    margin-top: 0.75rem;
    padding: 0.75rem;
    background: var(--muted);
    border-radius: var(--radius-md);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.8125rem;
    color: var(--foreground);
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .error-tips-section {
    padding-bottom: 4rem;
  }

  .section-title {
    text-align: center;
    margin-inline: auto;
    margin-bottom: 2rem;
  }

  .error-tips-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (min-width: 768px) {
    .error-tips-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .error-tip-card {
    border: 1px solid var(--border);
    background: var(--card);
    color: var(--card-foreground);
    border-radius: var(--radius);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition:
      border-color 150ms ease,
      background-color 150ms ease;
  }

  .error-tip-card:hover,
  .error-tip-card:focus-visible {
    border-color: color-mix(in srgb, var(--primary) 50%, transparent);
    background: color-mix(in srgb, var(--primary) 6%, var(--card));
  }

  .error-tip-card:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
  }

  .error-tip-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--primary) 12%, transparent);
    color: var(--primary);
  }

  .error-tip-card h3 {
    font-size: 1.125rem;
    margin: 0;
  }

  .error-tip-card p {
    color: var(--muted-foreground);
    margin: 0;
    font-size: 0.9375rem;
  }
</style>
