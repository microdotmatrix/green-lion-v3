---
import { db } from "@/lib/db";
import { caseStudies, clientLogos } from "@/lib/db/schema";
import { desc } from "drizzle-orm";
import Layout from "@/layouts/default.astro";
import CaseStudyCard from "@/components/catalog/case-study-card.astro";
import ClientLogos from "@/components/catalog/client-logos.astro";

// Fetch case studies and client logos directly from DB
const allCaseStudies = await db
  .select()
  .from(caseStudies)
  .orderBy(caseStudies.displayOrder, desc(caseStudies.createdAt));

const allClientLogos = await db
  .select()
  .from(clientLogos)
  .orderBy(clientLogos.displayOrder, desc(clientLogos.createdAt));
---

<Layout title="Case Studies">
  <section class="case-studies-hero">
    <div class="content text-center">
      <h1>Our <span class="text-primary">Clients</span> & Case Studies</h1>
      <p class="max-w-3xl mx-auto text-muted-foreground">
        Partnering with innovative companies to bring groundbreaking products to
        market.
      </p>
    </div>
  </section>

  <section class="case-studies-section">
    <div class="content">
      <h2 class="section-title accent-underline">Case Studies</h2>

      <div class="case-studies-grid">
        {
          allCaseStudies.map((study) => (
            <CaseStudyCard
              productName={study.productName}
              brandName={study.brandName}
              description={study.description}
              image={study.image}
              externalLink={study.externalLink}
            />
          ))
        }
      </div>

      {
        allCaseStudies.length === 0 && (
          <div class="empty-state">
            <p>No case studies available yet.</p>
          </div>
        )
      }
    </div>
  </section>

  {
    allClientLogos.length > 0 && (
      <section class="clients-section">
        <div class="content">
          <h2 class="section-title accent-underline">Our Clients</h2>
          <ClientLogos clients={allClientLogos} />
        </div>
      </section>
    )
  }
</Layout>

<style>
  .case-studies-hero {
    background: linear-gradient(to bottom, var(--secondary), var(--background));
  }

  .case-studies-hero h1 {
    margin-bottom: 1rem;
  }

  .case-studies-section {
    padding-bottom: 2rem;
  }

  .section-title {
    text-align: center;
    margin-bottom: 2rem;
  }

  .case-studies-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .case-studies-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .case-studies-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .clients-section {
    background: var(--secondary);
    padding: 3rem 0;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--muted-foreground);
  }
</style>
