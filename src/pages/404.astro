---
import Layout from "@/layouts/default.astro";

// Prerender so the build emits a static 404.html that the Netlify
// adapter can serve immediately for unmatched routes without invoking
// the SSR function.
export const prerender = true;
---

<Layout
  title="Page Not Found"
  description="The page you were looking for could not be found."
>
  <section class="error-hero">
    <div class="content text-center">
      <p class="error-eyebrow" aria-hidden="true">404</p>
      <h1>
        Page <span class="text-primary">Not Found</span>
      </h1>
      <p class="error-subtitle max-w-2xl mx-auto text-muted-foreground">
        We couldn&#39;t find the page you were looking for. It may have been
        moved, renamed, or never existed in the first place.
      </p>

      <div class="error-actions">
        <a href="/" class="primary-action">Return Home</a>
        <a href="/contact" class="secondary-action">Contact Support</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .error-hero {
    background: linear-gradient(to bottom, var(--secondary), var(--background));
    padding-block: 4rem 3rem;
    flex: 1;
    place-content: center;
    height: 100svh;
  }

  .error-eyebrow {
    font-family: var(--font-serif, serif);
    font-weight: 700;
    color: var(--primary);
    letter-spacing: 0.2em;
    font-size: clamp(1rem, 0.9rem + 0.5vw, 1.25rem);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
  }

  .error-hero h1 {
    margin-bottom: 1rem;
  }

  .error-subtitle {
    margin-bottom: 2rem;
  }

  .error-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .primary-action,
  .secondary-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius);
    padding: 0.625rem 1.25rem;
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid transparent;
    transition:
      background-color 150ms ease,
      color 150ms ease,
      box-shadow 200ms ease;
  }

  .primary-action {
    background: var(--primary);
    color: var(--primary-foreground);
  }
  .primary-action:hover,
  .primary-action:focus-visible {
    box-shadow: 0 6px 18px hsl(var(--primary) / 0.25);
    background: oklch(from var(--primary) l c calc(h * 1.3));
  }

  .secondary-action {
    border-color: var(--primary);
    color: var(--primary);
    background: transparent;
  }
  .secondary-action:hover,
  .secondary-action:focus-visible {
    background: var(--primary);
    color: var(--primary-foreground);
  }

  .primary-action:focus-visible,
  .secondary-action:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
  }
</style>
