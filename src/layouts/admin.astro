---
import "@/styles/global.css";

import AdminSidebar from "@/components/admin/admin-sidebar";
import { TailwindIndicator } from "@/components/elements/tailwind-indicator.tsx";
import Meta from "@/components/layout/meta.astro";

import { QueryProvider } from "@/components/providers/query-provider";
import { SITE } from "@/lib/config";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Admin Dashboard" } = Astro.props;

// Check if user is authenticated and has admin access
const user = Astro.locals.user;
const session = Astro.locals.session;

// Redirect if not authenticated
if (!user || !session) {
  return Astro.redirect("/signin?redirect=/admin");
}

// For now, all authenticated users can access admin
// TODO: Add role-based check once role field is added to user schema
// if (user.role !== "admin") {
//   return Astro.redirect("/?error=unauthorized");
// }
---

<!doctype html>
<html lang="en" class="dark">
  <Meta title={`${title} | Admin | ${SITE.title}`} description={description} />
  <body class="bg-zinc-950 text-zinc-50 antialiased">
    <QueryProvider client:only="react">
      <AdminSidebar client:only="react" user={user}>
        <slot />
      </AdminSidebar>
    </QueryProvider>
    {import.meta.env.DEV && <TailwindIndicator client:load />}
  </body>
</html>
