---
import "@/styles/global.css";

import { AdminLayout } from "@/components/admin/admin-layout";
import { TailwindIndicator } from "@/components/elements/tailwind-indicator.tsx";
import { Toaster } from "@/components/ui/sonner";
import Meta from "@/components/layout/meta.astro";
import UploadSSR from "@/components/providers/upload-ssr.astro";
import {
  buildAdminPageTitle,
  buildCanonicalForRequest,
  buildPageJsonLd,
  getEffectiveGlobalSeo,
  resolveSocialImageHref,
} from "@/lib/seo/global-seo";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Admin Dashboard" } = Astro.props;

// Check if user is authenticated and has admin access
const user = Astro.locals.user;
const session = Astro.locals.session;

// Redirect if not authenticated
if (!user || !session) {
  return Astro.redirect("/signin?redirect=/admin");
}

if (!user.approved) {
  return Astro.redirect("/signin?pending=1");
}

// For now, all approved users can access admin
// TODO: Add role-based check once role field is added to user schema

const adminUser = {
  id: user.id,
  name: user.name,
  email: user.email,
  image: user.image,
};

const effective = await getEffectiveGlobalSeo();
const pageTitle = buildAdminPageTitle(title, effective);
const social = resolveSocialImageHref(
  undefined,
  Astro.url.origin,
  Astro.site?.toString(),
  effective,
);
const canonicalURL = buildCanonicalForRequest({
  pathname: Astro.url.pathname,
  site: Astro.site?.toString(),
  requestOrigin: Astro.url.origin,
  canonicalBaseUrl: effective.canonicalBaseUrl,
});
const jsonLd = buildPageJsonLd({
  documentTitle: pageTitle,
  pageDescription: description,
  imageHref: social,
  effective,
});
---

<!doctype html>
<html lang="en" class="dark">
  <Meta
    title={pageTitle}
    author={effective.author}
    description={description}
    socialImageUrl={social}
    canonicalURL={canonicalURL}
    ogSiteName={effective.defaultTitle}
    jsonLd={jsonLd}
    robotsContent="noindex, nofollow"
    omitSiteVerification
    includeOpenGraph={false}
  />
  <UploadSSR />
  <body class="bg-zinc-950 text-zinc-50 antialiased">
    <AdminLayout client:load user={adminUser}>
      <slot />
    </AdminLayout>
    <Toaster client:load />
    {import.meta.env.DEV && <TailwindIndicator client:load />}
  </body>
</html>
