---
import Profile from "@/components/elements/profile.astro";
import type { TeamMember } from "@/lib/db/schema";

interface Props {
  members?: TeamMember[];
}

const { members = [] } = Astro.props;
---

<div class="content py-8 mt-12 max-w-screen-2xl">
  <header class="flex flex-col items-center justify-center">
    <h2 class="accent-underline text-center">Our Team</h2>
  </header>
  {
    members.length === 0 ? (
      <p class="text-center text-muted-foreground py-8">
        Team member profiles coming soon.
      </p>
    ) : (
      <div id="team-list" class="mx-auto px-4 py-8 sm:px-6 sm:py-12">
        <ul
          id="gli-team"
          class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-24"
        >
          {members.map((member, index) => (
            <li
              class:list={[
                "flex flex-col space-y-4",
                members.length % 2 !== 0 && index === members.length - 1
                  ? "lg:col-span-2 lg:max-w-xl lg:mx-auto"
                  : "",
              ]}
            >
              <Profile name={member.name} title={member.title} image={member.photoUrl ?? ""}>
                <div
                  class="prose prose-sm dark:prose-invert max-w-none [&_a]:text-primary [&_a]:underline [&_a]:underline-offset-2"
                  set:html={member.summaryHtml}
                />
              </Profile>
            </li>
          ))}
        </ul>
      </div>
    )
  }
</div>

<style>
  /*
   * Animate in team member cards when scrolling,
   * when using a browser that supports animation-timeline
   * and reduced motion is not preferred.
   */
  @supports (animation-timeline: scroll()) {
    @media (--motionOK) {
      #team-list ul {
        opacity: 1;
        @media (--lg-min) {
          animation: fade-in forwards;
          animation-timeline: scroll();
          animation-range: entry;
          animation-range: 0 100px;
        }
        & > li {
          animation: item-in-left forwards;
          animation-timeline: view();
          animation-range: 0 33%;
          animation-timing-function: cubic-bezier(0.175, 0.885, 0.32, 1.275);
          @media (--lg-min) {
            animation-range: entry;
          }
        }
        & > li:nth-child(2n) {
          animation: item-in-right forwards;
          animation-timeline: view();
          animation-range: 0 33%;
          animation-timing-function: cubic-bezier(0.175, 0.885, 0.32, 1.275);
          @media (--lg-min) {
            animation-range: entry;
          }
        }
      }
    }
  }
</style>
