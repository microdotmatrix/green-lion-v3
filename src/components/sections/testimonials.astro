---
import { TestimonialsCarousel } from "@/components/sections/testimonials-carousel";
import { db } from "@/lib/db";
import { testimonials } from "@/lib/db/schema";
import { desc } from "drizzle-orm";

const allTestimonials = await db
  .select()
  .from(testimonials)
  .orderBy(testimonials.displayOrder, desc(testimonials.createdAt));
---

{
  allTestimonials.length > 0 && (
    <div class="testimonials-section py-16 md:py-24">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <h4 class="mx-auto text-center font-semibold tracking-tight fl-my-8/12 accent-underline">
          What Our Clients Say
        </h4>
        <TestimonialsCarousel client:load testimonials={allTestimonials} />
      </div>
    </div>
  )
}

<style>
  .testimonials-section {
    background: linear-gradient(
      to bottom,
      transparent 50%,
      var(--color-secondary)
    );
  }
</style>
