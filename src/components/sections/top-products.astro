---
import { db } from "@/lib/db";
import { categories, products } from "@/lib/db/schema";
import CategoryCard from "@/components/catalog/category-card.astro";
import { count } from "drizzle-orm";

const topCategories = await db
  .select()
  .from(categories)
  .orderBy(categories.displayOrder, categories.name)
  .limit(6);

const productCounts = await db
  .select({
    categoryId: products.categoryId,
    count: count(),
  })
  .from(products)
  .groupBy(products.categoryId);

const countMap = new Map(productCounts.map((entry) => [entry.categoryId, entry.count]));

function slugify(name: string): string {
  return name
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");
}
---

<div class="content top-products-section">
  <div class="top-products-header">
    <div class="top-products-copy">
      <p class="top-products-kicker">Featured Catalog</p>
      <h2 class="accent-underline">Top Products</h2>
      <p class="top-products-description">
        Explore our leading product categories and jump into the full catalog for
        more options, specifications, and customization details.
      </p>
    </div>

    <a href="/products" class="top-products-link">See More Products</a>
  </div>

  {
    topCategories.length > 0 ? (
      <div class="top-products-grid">
        {topCategories.map((category) => (
          <CategoryCard
            name={category.name}
            description={category.description}
            imageUrl={category.imageUrl}
            productCount={countMap.get(category.id) || 0}
            href={`/products/${slugify(category.name)}`}
          />
        ))}
      </div>
    ) : (
      <div class="top-products-empty">
        <p>No product categories available yet.</p>
        <a href="/products" class="top-products-link">Browse Products</a>
      </div>
    )
  }
</div>

<style>
  .top-products-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .top-products-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }

  .top-products-copy {
    max-width: 42rem;
  }

  .top-products-kicker {
    margin: 0 0 0.75rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--primary);
  }

  .top-products-description {
    margin: 1rem 0 0;
    max-width: 38rem;
    color: var(--muted-foreground);
    line-height: 1.7;
  }

  .top-products-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-md);
    background: var(--primary);
    color: var(--primary-foreground);
    font-weight: 600;
    text-decoration: none;
    transition:
      transform 200ms ease,
      box-shadow 200ms ease;
  }

  .top-products-link:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 24px color-mix(in srgb, var(--primary) 22%, transparent);
  }

  .top-products-grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .top-products-grid > :nth-child(n + 4) {
    display: none;
  }

  .top-products-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 3rem 1.5rem;
    text-align: center;
    border: 1px dashed var(--border);
    border-radius: var(--radius-lg);
    color: var(--muted-foreground);
  }

  @media (min-width: 640px) {
    .top-products-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .top-products-header {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      gap: 2rem;
    }

    .top-products-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .top-products-grid > :nth-child(n + 4) {
      display: flex;
    }
  }
</style>
