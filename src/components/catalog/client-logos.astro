---
import type { ClientLogo } from "@/lib/db/schema";

interface Props {
  clients: ClientLogo[];
}

const { clients } = Astro.props;

function getCols(n: number, max: number): number {
  const cap = Math.min(n, max);
  for (let c = cap; c >= 2; c--) {
    if (n % c === 0) return c;
  }
  return cap;
}

const count = clients.length;
const colsXs = getCols(count, 2);
const colsSm = getCols(count, 3);
const colsMd = getCols(count, 4);
const colsLg = getCols(count, 5);
const colsXl = getCols(count, 6);
---

<div
  class="client-logos"
  style={`--cols-xs:${colsXs};--cols-sm:${colsSm};--cols-md:${colsMd};--cols-lg:${colsLg};--cols-xl:${colsXl}`}
>
  {
    clients.map((client) => (
      <a
        href={client.externalLink}
        target="_blank"
        rel="noopener"
        class="client-logo"
        title={client.companyName}
      >
        <img src={client.logoUrl} alt={client.companyName} loading="lazy" />
      </a>
    ))
  }
</div>

<style>
  .client-logos {
    display: grid;
    grid-template-columns: repeat(var(--cols-xs), 1fr);
    gap: 1rem;
  }

  @media (min-width: 480px) {
    .client-logos {
      grid-template-columns: repeat(var(--cols-sm), 1fr);
    }
  }

  @media (min-width: 768px) {
    .client-logos {
      grid-template-columns: repeat(var(--cols-md), 1fr);
    }
  }

  @media (min-width: 1024px) {
    .client-logos {
      grid-template-columns: repeat(var(--cols-lg), 1fr);
      gap: 1.5rem;
    }
  }

  @media (min-width: 1280px) {
    .client-logos {
      grid-template-columns: repeat(var(--cols-xl), 1fr);
    }
  }

  .client-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    transition:
      transform 200ms ease,
      border-color 200ms ease,
      box-shadow 200ms ease;
  }

  .client-logo:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--primary) 40%, transparent);
    box-shadow: 0 8px 24px color-mix(in srgb, var(--primary) 10%, transparent);
  }

  .client-logo img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.6;
    transition:
      filter 200ms ease,
      opacity 200ms ease;
  }

  .client-logo:hover img {
    filter: grayscale(0%);
    opacity: 1;
  }
</style>
