---
interface Props {
  productName: string;
  brandName: string;
  description: string;
  image: string;
  externalLink: string;
}

const { productName, brandName, description, image, externalLink } =
  Astro.props;
---

<a
  href={externalLink}
  target="_blank"
  rel="noopener noreferrer"
  class="case-study-card group"
>
  <div class="case-study-image">
    <img src={image} alt={productName} loading="lazy" />
  </div>

  <div class="case-study-content">
    <h3 class="case-study-title">{productName}</h3>
    <span class="case-study-brand">{brandName}</span>
    <p class="case-study-description">{description}</p>
  </div>
</a>

<style>
  .case-study-card {
    display: flex;
    flex-direction: column;
    background: var(--card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      transform 200ms ease,
      box-shadow 200ms ease,
      border-color 200ms ease;
  }

  .case-study-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px color-mix(in srgb, var(--primary) 15%, transparent);
    border-color: color-mix(in srgb, var(--primary) 40%, transparent);
  }

  .case-study-image {
    aspect-ratio: 16 / 10;
    background: var(--secondary);
    overflow: hidden;
  }

  .case-study-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 300ms ease;
  }

  .case-study-card:hover .case-study-image img {
    transform: scale(1.05);
  }

  .case-study-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .case-study-title {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.3;
  }

  .case-study-brand {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--primary);
  }

  .case-study-description {
    font-size: 0.8125rem;
    color: var(--muted-foreground);
    margin: 0;
    margin-top: 0.25rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
