---
interface Props {
  name: string;
  description?: string | null;
  imageUrl?: string | null;
  productCount: number;
  href: string;
}

const { name, description, imageUrl, productCount, href } = Astro.props;
---

<a href={href} class="category-card group">
  <div class="category-image">
    {
      imageUrl ? (
        <img src={imageUrl} alt={name} loading="lazy" />
      ) : (
        <div class="category-placeholder">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="48"
            height="48"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="m7.5 4.27 9 5.15" />
            <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z" />
            <path d="m3.3 7 8.7 5 8.7-5" />
            <path d="M12 22V12" />
          </svg>
        </div>
      )
    }
  </div>
  <div class="category-content">
    <h3 class="category-name">{name}</h3>
    {description && <p class="category-description">{description}</p>}
    <div class="category-footer">
      <span class="product-count"
        >{productCount} {productCount === 1 ? "product" : "products"}</span
      >
      <span class="browse-button">
        Browse
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </span>
    </div>
  </div>
</a>

<style>
  .category-card {
    display: flex;
    flex-direction: column;
    background: var(--card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    overflow: hidden;
    transition:
      transform 200ms ease,
      box-shadow 200ms ease,
      border-color 200ms ease,
      outline-color 200ms ease;
    text-decoration: none;
    color: inherit;
    outline: 2px solid transparent;
    outline-offset: 3px;
  }

  .category-card:hover,
  .category-card:focus-visible {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px color-mix(in srgb, var(--primary) 15%, transparent);
    border-color: color-mix(in srgb, var(--primary) 40%, transparent);
  }

  .category-card:focus-visible {
    outline-color: var(--primary);
  }

  .category-image {
    aspect-ratio: 16 / 10;
    background: var(--secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .category-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 300ms ease;
  }

  .category-card:hover .category-image img,
  .category-card:focus-visible .category-image img {
    transform: scale(1.05);
  }

  .category-placeholder {
    color: var(--muted-foreground);
    opacity: 0.5;
  }

  .category-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .category-name {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
  }

  .category-description {
    font-size: 0.875rem;
    color: var(--muted-foreground);
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .category-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.75rem;
  }

  .product-count {
    font-size: 0.75rem;
    color: var(--muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .browse-button {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--primary);
    transition: gap 200ms ease;
  }

  .category-card:hover .browse-button,
  .category-card:focus-visible .browse-button {
    gap: 0.625rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .category-card,
    .category-image img,
    .browse-button {
      transition:
        outline-color 200ms ease,
        border-color 200ms ease;
    }

    .category-card:hover,
    .category-card:focus-visible {
      transform: none;
    }

    .category-card:hover .category-image img,
    .category-card:focus-visible .category-image img {
      transform: none;
    }
  }
</style>
