---
// Dark Mode toggle icon

const props = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width="1em"
  height="1em"
  viewBox="0 0 24 24"
  {...props}
>
  <path
    fill="currentColor"
    d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2S2 6.477 2 12s4.477 10 10 10m0-1.5v-17a8.5 8.5 0 0 1 0 17"
  ></path>
</svg>

<style>
  svg {
    filter: drop-shadow(
      0 0 1px color-mix(in srgb, var(--primary) 10%, transparent)
    );
    transition: all 0.2s ease-in-out;
    &:hover {
      filter: drop-shadow(
        0 0 3px color-mix(in srgb, var(--primary) 40%, transparent)
      );
    }
  }
</style>
