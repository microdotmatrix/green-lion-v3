---
// Profile card component used in team members section.
// `image` accepts either an astro:assets imported image object or a plain URL string.

import { Image } from "astro:assets";

const { name, title, image } = Astro.props;
const isUrl = typeof image === "string";
---

<header class="flex items-center bg-secondary">
  <figure class="flex-none fl-w-28/40">
    {
      isUrl ? (
        <img
          src={image}
          alt={name}
          class="aspect-square size-full object-cover"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <Image
          src={image}
          alt={name}
          class="aspect-square size-full object-cover"
        />
      )
    }
  </figure>
  <div class="flex-1 fl-space-y-1/2 fl-px-4/8">
    <h5>{name}</h5>
    <p class="text-sm text-muted-foreground">{title}</p>
  </div>
</header>
<div class="flex flex-col space-y-4">
  <slot />
</div>
