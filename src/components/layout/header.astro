---
// Global header component

import Logo from "../elements/logo.astro";
import Navigation from "../layout/navigation.astro";
import ThemeSwitch from "../theme/toggle.astro";
import { ShoppingCart } from "../icons";
---

<header class="bg-secondary sticky top-0 mt-0 z-50 w-full">
  <div class="mx-auto max-w-screen fl-px-2/4">
    <div class="flex fl-h-16/24 items-center justify-between">
      <div class="md:flex md:items-center md:gap-4 relative z-50">
        <a class="flex fl-mt-4/12 relative z-50" href="/">
          <Logo id="gli-logo" class="fl-size-24/40 object-contain" />
          <span class="sr-only">Home</span>
        </a>
        <a
          href="/"
          id="company-title"
          class="hidden md:block uppercase fl-text-2xl/3xl font-serif"
        >
          <strong>Green Lion</strong> Innovations
        </a>
      </div>

      <div class="hidden xl:block">
        <Navigation role="global" />
      </div>

      <div id="mobile-nav" class="flex xl:hidden">
        <Navigation role="mobile" />
      </div>

      <div class="flex items-center gap-4">
        <div class="flex items-center gap-2 2xl:pr-6">
          <!-- Quote Cart Link -->
          <a
            href="/quote"
            id="quote-cart-link"
            class="relative inline-flex items-center justify-center rounded-md p-2 text-foreground hover:bg-accent hover:text-accent-foreground transition-colors group z-50"
            title="View Quote"
          >
            <ShoppingCart
              class="size-8 group-hover:opacity-90 transition-all duration-300 group-hover:scale-110"
            />
            <span
              id="quote-cart-count"
              class="absolute top-0.5 right-1 flex items-center justify-center min-w-5 h-5 px-1.5 text-xs font-bold text-primary-foreground bg-primary rounded-full"
              style="display: none;"
            >
              0
            </span>
            <span class="sr-only">View Quote</span>
          </a>

          <ThemeSwitch />
        </div>

        <div class="block xl:hidden z-50">
          <button
            aria-label="Open mobile navigation"
            id="mobile-nav-button"
            class="rounded bg-popover p-2 text-popover-foreground transition hover:text-gray-600/75 cursor-pointer"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="size-5 menu"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="1em"
              height="1em"
              viewBox="0 0 32 32"
              class="size-5 close"
            >
              <path
                fill="currentColor"
                d="M17.414 16L24 9.414L22.586 8L16 14.586L9.414 8L8 9.414L14.586 16L8 22.586L9.414 24L16 17.414L22.586 24L24 22.586z"
              ></path>
            </svg>
            <span class="sr-only">Toggle navigation</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  #gli-logo {
    --blur-amount: 30px;
    --blur-opacity: 50%;
    --blur-brightness: 1;
    filter: drop-shadow(
        0px 0px var(--blur-amount)
          color-mix(in srgb, var(--primary) var(--blur-opacity), transparent)
      )
      brightness(var(--blur-brightness));
    transition: filter 400ms ease-in-out;
    &:hover {
      --blur-amount: 10px;
      --blur-opacity: 80%;
      --blur-brightness: 1.2;
    }
  }

  #company-title {
    font-weight: 300;

    & > strong {
      font-weight: 750;
    }
    @media (width >= 1440px) {
      letter-spacing: 0.08vw;
      word-spacing: 0.1rem;
    }
  }

  #mobile-nav {
    overflow: hidden;
    position: fixed;
    z-index: 40;
    inset: 0;
    width: 100%;
    height: 75%;
    background-color: var(--secondary);
    transform: translateY(-100%);
    transition: transform 250ms cubic-bezier(0.39, 0.575, 0.565, 1);
    &.open {
      transform: translateY(0);
      transition: transform 250ms cubic-bezier(0.39, 0.575, 0.565, 1);
    }
  }
  #mobile-nav-button {
    display: block;
    & > svg.menu {
      display: block;
    }
    & > svg.close {
      display: none;
    }
    &.open {
      & > svg.menu {
        display: none;
      }
      & > svg.close {
        display: block;
      }
    }
  }
</style>

<script is:inline>
  // Open/close mobile navigation menu
  function toggleMobileNav() {
    const mobileNav = document.getElementById("mobile-nav");
    const mobileNavTrigger = document.getElementById("mobile-nav-button");
    mobileNav?.classList.toggle("open");
    mobileNavTrigger?.classList.toggle("open");
  }

  // Set mobile navigation trigger element and auto-close navigation menu when a link is clicked
  function initializeNav() {
    const mobileNavTrigger = document.getElementById("mobile-nav-button");
    const links = document.querySelectorAll("#nav-link");
    mobileNavTrigger?.addEventListener("click", toggleMobileNav);
    links.forEach((link) => {
      link.addEventListener("click", toggleMobileNav);
    });
  }

  // Update quote cart count badge
  function updateQuoteCartCount() {
    const countBadge = document.getElementById("quote-cart-count");
    if (!countBadge) return;

    try {
      const cart = localStorage.getItem("quoteCart");
      const items = cart ? JSON.parse(cart) : [];
      const total = items.length;

      if (total > 0) {
        countBadge.textContent = total.toString();
        countBadge.style.display = "flex";
      } else {
        countBadge.style.display = "none";
      }
    } catch (e) {
      countBadge.style.display = "none";
    }
  }

  // Initialize on page load
  function initializeAll() {
    initializeNav();
    updateQuoteCartCount();
  }

  // Listen for cart updates
  window.addEventListener("quote-cart-updated", updateQuoteCartCount);
  window.addEventListener("storage", (e) => {
    if (e.key === "quoteCart") updateQuoteCartCount();
  });

  document.addEventListener("astro:after-swap", initializeAll);
  initializeAll();
</script>
