---
// Global footer component

import { Copyright } from "@/components/icons";
import { NAV_LINKS } from "@/lib/config";
---

<footer class="bg-secondary/50 border-t py-8">
  <div class="fl-px-4/8 lg:px-[8vw]">
    <div
      class="flex flex-col items-center justify-between gap-12 py-6 md:flex-row"
    >
      <section class="flex flex-col">
        <address
          class="text-gray-400 text-sm flex flex-col text-center md:text-left"
        >
          <span class="text-lg font-semibold" style="font-style: normal"
            >Green Lion Innovations</span
          >
          <span>1312 17th St #652</span>
          <span>Denver, CO 80202</span>
          <span>United States</span>
        </address>
      </section>

      <section class="footer-nav ml-auto" aria-label="Footer navigation">
        <h2 class="footer-heading">Explore</h2>
        <ul class="footer-links">
          {
            NAV_LINKS.map(({ link, title }) => (
              <li>
                <a href={`/${link}`}>{title}</a>
              </li>
            ))
          }
        </ul>
      </section>
    </div>

    <div class="py-8 text-center text-sm text-gray-400">
      <span class="flex gap-2 items-center justify-center">
        <Copyright class="size-6 align-middle" />
        {new Date().getFullYear()} - Green Lion Innovations. All rights reserved.
      </span>
    </div>
  </div>
</footer>

<style>
  .footer-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .footer-heading {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--foreground);
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem 1.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .footer-links a {
    color: var(--muted-foreground);
    text-decoration: none;
    transition: color 200ms ease;
  }

  .footer-links a:hover {
    color: var(--primary);
  }

  @media (min-width: 768px) {
    .footer-nav {
      align-items: flex-start;
    }

    .footer-links {
      justify-content: flex-start;
    }
  }
</style>
