---
interface Props {
  title: string;
  slug: string;
  excerpt: string;
  coverImageUrl: string | null;
  publishedAt: Date | string | null;
  categoryName: string | null;
  categorySlug: string | null;
  readTime: string;
  variant?: "hero" | "grid";
}

const {
  title,
  slug,
  excerpt,
  coverImageUrl,
  publishedAt,
  categoryName,
  categorySlug,
  readTime,
  variant = "grid",
} = Astro.props;

const hasExcerpt = excerpt.trim().length > 0;

function formatDate(date: Date | string | null): string {
  if (!date) return "";
  return new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(new Date(date));
}
---

<article class:list={["blog-card", `blog-card--${variant}`]}>
  <div class="card-media">
    {
      coverImageUrl ? (
        <img
          src={coverImageUrl}
          alt={title}
          loading="lazy"
          class="card-image"
        />
      ) : (
        <div class="card-image-placeholder" aria-hidden="true" />
      )
    }
  </div>

  <div class="card-body">
    {
      categorySlug && categoryName && (
        <a href={`/blog/category/${categorySlug}`} class="category-badge">
          {categoryName}
        </a>
      )
    }

    <a href={`/blog/${slug}`} class="post-title">
      {title}
    </a>

    {
      hasExcerpt && (
        <p
          class:list={[
            "post-excerpt",
            { "post-excerpt--clamp": variant === "grid" },
          ]}
        >
          {excerpt}
        </p>
      )
    }

    <div class="post-meta">
      {publishedAt && <span class="post-date">{formatDate(publishedAt)}</span>}
      {
        publishedAt && (
          <span class="meta-sep" aria-hidden="true">
            ·
          </span>
        )
      }
      <span class="post-read-time">{readTime}</span>
    </div>
  </div>
</article>

<style>
  .blog-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
    text-decoration: none;
    color: inherit;
  }

  .blog-card:hover {
    border-color: color-mix(in srgb, var(--primary) 30%, transparent);
    box-shadow: 0 8px 24px color-mix(in srgb, var(--primary) 10%, transparent);
  }

  .card-media {
    flex-shrink: 0;
  }

  .card-image {
    width: 100%;
    display: block;
    object-fit: cover;
  }

  .blog-card--hero .card-image,
  .blog-card--hero .card-image-placeholder {
    aspect-ratio: 16 / 9;
  }

  .blog-card--grid .card-image,
  .blog-card--grid .card-image-placeholder {
    aspect-ratio: 4 / 3;
  }

  .card-image-placeholder {
    width: 100%;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--primary) 20%, var(--card)),
      color-mix(in srgb, var(--primary) 40%, var(--secondary))
    );
  }

  .card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }

  .category-badge {
    display: inline-block;
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    color: var(--primary);
    border-radius: var(--radius-md);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.625rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    width: fit-content;
  }

  .category-badge:hover {
    background: color-mix(in srgb, var(--primary) 20%, transparent);
  }

  .post-title {
    font-weight: 600;
    color: inherit;
    text-decoration: none;
    line-height: 1.3;
    display: block;
  }

  .blog-card--hero .post-title {
    font-size: 1.5rem;
  }

  .blog-card--grid .post-title {
    font-size: 1rem;
  }

  .post-title:hover {
    color: var(--primary);
  }

  .post-excerpt {
    color: var(--muted-foreground);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
  }

  .post-excerpt--clamp {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--muted-foreground);
    margin-top: auto;
  }

  .meta-sep {
    opacity: 0.5;
  }
</style>
