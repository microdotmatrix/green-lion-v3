---
import { resolveResponsiveBlogExcerpts } from "@/lib/blog-excerpt";
import PostMeta from "@/components/blog/post-meta.astro";

interface Props {
  title: string;
  slug: string;
  excerpt: string | null;
  body?: string | null;
  coverImageUrl: string | null;
  publishedAt: Date | string | null;
  categoryName: string | null;
  categorySlug: string | null;
  readTime: string;
  variant?: "hero" | "grid";
}

const {
  title,
  slug,
  excerpt,
  body,
  coverImageUrl,
  publishedAt,
  categoryName,
  categorySlug,
  readTime,
  variant = "grid",
} = Astro.props;

const responsiveExcerpt = resolveResponsiveBlogExcerpts(excerpt, body);
const hasExcerpt = responsiveExcerpt.base.trim().length > 0;
---

<article class:list={["blog-card", `blog-card--${variant}`]}>
  <div class="card-media">
    <a
      href={`/blog/${slug}`}
      class="card-media-link"
      aria-label={`Read post: ${title}`}
    >
      {
        coverImageUrl ? (
          <img
            src={coverImageUrl}
            alt={title}
            loading="lazy"
            class="card-image"
          />
        ) : (
          <div class="card-image-placeholder" aria-hidden="true" />
        )
      }
    </a>
    {
      categorySlug && categoryName && (
        <a href={`/blog/category/${categorySlug}`} class="category-badge">
          {categoryName}
        </a>
      )
    }
  </div>

  <div class="card-body">
    <a href={`/blog/${slug}`} class="post-title">
      {title}
    </a>

    {
      hasExcerpt && (
        <p
          class:list={[
            "post-excerpt",
            { "post-excerpt--clamp": variant === "grid" },
          ]}
        >
          <span class="post-excerpt__text post-excerpt__text--base">
            {responsiveExcerpt.base}
          </span>
          <span class="post-excerpt__text post-excerpt__text--lg">
            {responsiveExcerpt.lg}
          </span>
          <span class="post-excerpt__text post-excerpt__text--xxxl">
            {responsiveExcerpt.xxxl}
          </span>
        </p>
      )
    }

    <PostMeta publishedAt={publishedAt} readTime={readTime} class="post-meta" />
  </div>
</article>

<style>
  .blog-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
    text-decoration: none;
    color: inherit;
  }

  .blog-card:hover {
    border-color: color-mix(in srgb, var(--primary) 30%, transparent);
    box-shadow: 0 8px 24px color-mix(in srgb, var(--primary) 10%, transparent);
  }

  .card-media {
    flex-shrink: 0;
    position: relative;
  }

  .card-media-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-image {
    width: 100%;
    display: block;
    object-fit: cover;
  }

  .blog-card--hero .card-image,
  .blog-card--hero .card-image-placeholder {
    aspect-ratio: 16 / 9;
  }

  .blog-card--grid .card-image,
  .blog-card--grid .card-image-placeholder {
    aspect-ratio: 4 / 3;
  }

  .card-image-placeholder {
    width: 100%;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--primary) 20%, var(--card)),
      color-mix(in srgb, var(--primary) 40%, var(--secondary))
    );
  }

  .card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }

  .category-badge {
    position: absolute;
    bottom: 0.625rem;
    right: 0.625rem;
    display: inline-block;
    background: color-mix(in srgb, var(--background) 70%, transparent);
    backdrop-filter: blur(4px);
    color: var(--primary);
    border-radius: var(--radius-md);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.625rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    width: fit-content;
    z-index: 1;
  }

  .category-badge:hover,
  .category-badge:focus {
    background: color-mix(in srgb, var(--primary) 60%, transparent);
  }

  .post-title {
    font-weight: 600;
    color: inherit;
    text-decoration: none;
    line-height: 1.3;
    display: block;
  }

  .blog-card--hero .post-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
  }

  .blog-card--grid .post-title {
    font-size: clamp(1.23rem, 2vw, 1.42rem);
  }

  .post-title:hover {
    color: var(--primary);
  }

  .post-excerpt {
    color: var(--muted-foreground);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
  }

  .post-excerpt__text {
    display: none;
  }

  .post-excerpt__text--base {
    display: inline;
  }

  .post-excerpt--clamp {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .post-excerpt__text--base {
      display: none;
    }

    .post-excerpt__text--lg {
      display: inline;
    }

    .post-excerpt--clamp {
      -webkit-line-clamp: 4;
    }
  }

  @media (min-width: 1920px) {
    .post-excerpt__text--lg {
      display: none;
    }

    .post-excerpt__text--xxxl {
      display: inline;
    }

    .post-excerpt--clamp {
      -webkit-line-clamp: 6;
    }
  }

  .post-meta {
    margin-top: auto;
  }
</style>
