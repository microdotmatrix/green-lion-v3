---
interface Props {
  title: string;
  slug: string;
  excerpt: string;
  coverImageUrl: string | null;
  publishedAt: Date | string | null;
  categoryName: string | null;
  categorySlug: string | null;
  readTime: string;
}

const {
  title,
  slug,
  excerpt,
  coverImageUrl,
  publishedAt,
  categoryName,
  categorySlug,
  readTime,
} = Astro.props;

const hasExcerpt = excerpt.trim().length > 0;

function formatDate(date: Date | string | null): string {
  if (!date) return "";
  return new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(new Date(date));
}
---

<article class="featured-post">
  <div class="featured-image-wrap">
    {
      coverImageUrl ? (
        <img
          src={coverImageUrl}
          alt={title}
          loading="eager"
          class="featured-image"
        />
      ) : (
        <div class="featured-image-placeholder" aria-hidden="true" />
      )
    }
  </div>

  <div class="featured-content-card shadow-xl shadow-gray-700/10">
    {
      categorySlug && categoryName && (
        <a href={`/blog/category/${categorySlug}`} class="category-badge">
          {categoryName}
        </a>
      )
    }

    <a href={`/blog/${slug}`} class="post-title">
      {title}
    </a>

    {hasExcerpt && <p class="post-excerpt">{excerpt}</p>}

    <div class="post-meta">
      {publishedAt && <span class="post-date">{formatDate(publishedAt)}</span>}
      {
        publishedAt && (
          <span class="meta-sep" aria-hidden="true">
            ·
          </span>
        )
      }
      <span class="post-read-time">{readTime}</span>
    </div>
  </div>
</article>

<style>
  .featured-post {
    position: relative;
    display: grid;
    grid-template-columns: 42fr 10fr 48fr;
    align-items: center;
    min-height: 420px;
    overflow: hidden;
  }

  .featured-image-wrap {
    grid-column: 1 / 3;
    grid-row: 1;
    height: 100%;
    max-block-size: 640px;
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .featured-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .featured-image-placeholder {
    width: 100%;
    height: 100%;
    min-height: 420px;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--primary) 30%, oklch(0.12 0 0)),
      color-mix(in srgb, var(--primary) 15%, oklch(0.08 0 0))
    );
  }

  .featured-content-card {
    grid-column: 2 / 4;
    grid-row: 1;
    z-index: 1;
    margin: 2rem;
    padding: 2rem 2.5rem;
    background: color-mix(in srgb, var(--card) 92%, transparent);
    border: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
    border-radius: var(--radius-xl);
    backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .category-badge {
    display: inline-block;
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    color: var(--primary);
    border-radius: var(--radius-md);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.625rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    width: fit-content;
  }

  .category-badge:hover {
    background: color-mix(in srgb, var(--primary) 20%, transparent);
  }

  .post-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    color: var(--card-foreground);
    text-decoration: none;
    line-height: 1.25;
    display: block;
  }

  .post-title:hover {
    color: var(--primary);
  }

  .post-excerpt {
    color: var(--muted-foreground);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-meta {
    margin-top: auto;
    padding-top: calc(var(--spacing) * 6);
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--muted-foreground);
  }

  .meta-sep {
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .featured-post {
      grid-template-columns: 1fr;
      min-height: unset;
    }

    .featured-image-wrap {
      grid-column: 1;
      grid-row: 1;
      min-height: unset;
      aspect-ratio: 16 / 9;
      height: auto;
    }

    .featured-image {
      aspect-ratio: 16 / 9;
      height: auto;
    }

    .featured-image-placeholder {
      min-height: unset;
      aspect-ratio: 16 / 9;
      height: auto;
    }

    .featured-content-card {
      grid-column: 1;
      grid-row: 2;
      margin: 0;
      border-radius: 0 0 var(--radius-xl) var(--radius-xl);
      border-top: none;
      backdrop-filter: none;
      background: var(--card);
    }
  }
</style>
